rules_version = '2';

// =============================================================
//  Vive Quintay - Reglas de seguridad Firestore
//  Proyecto: vive-quintay-spa
//
//  Modelo:
//   - OPERATIVO (patentes / config): el Verificador AHORA exige login
//     (request.auth != null). Escribe config solo Python (Admin SDK).
//   - ATRIBUCION (ingresos): log append-only por operador (Fase 1/2).
//   - FINANCIERO (cierres / stats / catalogo Makito): solo el admin
//     autenticado (isAdmin por email). El cliente nunca escribe plata.
//   - Python (caja) escribe con Admin SDK, que IGNORA estas reglas.
// =============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'admin@vivequintay.cl';
    }

    // OPERATIVO (Verificador — AHORA exige login)
    match /activos/{doc} {
      allow read, write: if request.auth != null;
    }
    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ATRIBUCION (Fase 1/2) — log append-only de ingresos por operador.
    // Crear: cualquier operador logueado, SOLO bajo su propio uid (anti-forja).
    // Leer: solo el admin del Verificador (claim rol == administrador) para el Panel.
    // Inmutable: nadie edita ni borra.
    match /ingresos/{doc} {
      allow create: if request.auth != null
                    && request.resource.data.operador_uid == request.auth.uid;
      allow read: if request.auth != null
                  && request.auth.token.rol == 'administrador';
      allow update, delete: if false;
    }

    // FINANCIERO (solo admin autenticado)
    match /historico_cierres/{doc} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /admin_stats/{doc} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /configuracion/{doc} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // GESTION DE CATALOGO MAKITO (admin, desde el telefono)
    // El catalogo lo ESPEJA solo la caja (Admin SDK). El telefono admin lo LEE
    // (para escanear/listar) y deja ORDENES de cambio en 'makito_cambios'. La caja
    // las aplica y las marca (Admin SDK); el cliente NO edita catalogo ni ordenes.
    match /makito_catalogo/{doc} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /makito_cambios/{doc} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    // Todo lo demas: cerrado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
